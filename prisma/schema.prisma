generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Users {
  id               Int            @id @default(autoincrement())
  pseudo           String
  email            String         @unique
  password         String
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  progressions     Progressions[]
}

enum PuzzleType {
  overflowing_palette
  energy_matrix
  signals_console
}

enum DifficultyType {
  easy
  medium
  hard
}

model Progressions {
  id         Int            @id @default(autoincrement())
  user       Users          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  type       PuzzleType
  difficulty DifficultyType
  level      Int
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([userId, type, difficulty])
}